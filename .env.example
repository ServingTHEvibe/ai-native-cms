# ---- Core ----
# Master key for the owner login (full access to every site). CHANGE THIS.
OWNER_MASTER_KEY=change-me-owner-key
# Secret used to sign session tokens (HMAC). Any long random string.
SERVER_SECRET=change-me-to-a-long-random-string
PORT=3000

# ---- Storage ----
# Leave MONGODB_URI empty to use filesystem storage (./data).
# Set it to a MongoDB connection string (e.g. MongoDB Atlas) to persist on Vercel.
MONGODB_URI=
MONGODB_DB=ai_cms

# ---- AI chat (optional) ----
# Provide ONE of these to enable the natural-language editor.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ---- Publishing to Vercel (optional) ----
# A Vercel API token, used by the Publish step to deploy a site's static bundle.
# Each site can also store its own token/project; this is the default fallback.
VERCEL_TOKEN=
VERCEL_TEAM_ID=
